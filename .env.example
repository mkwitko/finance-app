# Copy to .env.local and fill in. All EXPO_PUBLIC_* vars are inlined into the app
# bundle at build time (they are NOT secret — treat them as public).

# Backend API. On a physical device use your machine's LAN IP (e.g.
# http://192.168.0.6:3000), NOT localhost. Android emulator: http://10.0.2.2:3000.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Sign-In. Web client ID is the token audience the backend verifies.
# iOS client ID is required for native sign-in on iOS (its reversed form also
# goes in app.json -> @react-native-google-signin/google-signin -> iosUrlScheme).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Stripe (optional; card payments work without the merchant id / Apple Pay).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.financeapp
EXPO_PUBLIC_STRIPE_URL_SCHEME=financeapp
