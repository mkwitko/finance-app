                            "type": "string"
                          },
                          "aiCategorized": {
                            "type": "boolean"
                          },
                          "aiConfidence": {
                            "anyOf": [
                              {
                                "type": "integer",
                                "minimum": -9007199254740991,
                                "maximum": 9007199254740991
                              },
                              {
                                "type": "null"
                              }
                            ]
                          },
                          "category": {
                            "anyOf": [
                              {
