          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "individual",
                      "family",
                      "shared",
                      "kids"
                    ]
                  }
                },
                "required": [
                  "name",
                  "type"
                ]
              }
            }
